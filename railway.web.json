{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "phases": {
        "install": {
          "dependsOn": ["setup"],
          "cmds": ["cd apps/web && npm ci"]
        },
        "build": {
          "dependsOn": ["install"],
          "cmds": ["cd apps/web && npm run build"]
        }
      }
    }
  },
  "deploy": {
    "startCommand": "cd apps/web && npm run start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
